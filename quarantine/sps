signatures = [
    "powershell",
    "cmd.exe",
    "wget",
    "curl",
    "base64"
]

IGNORE_FILES = [
    "sps_security.py",
    "signatures.txt"
]

IGNORE_FOLDERS = [
    "quarantine",
    "__pycache__"
]

QUARANTINE_FOLDER = "quarantine"


def loading():

    print(Fore.YELLOW + "Initializing SPS-SECURITY", end="")

    for i in range(5):
        time.sleep(0.4)
        print(".", end="", flush=True)

    print(Fore.GREEN + "\nSystem ready!\n")


def get_hash(file_path):

    sha256 = hashlib.sha256()

    try:

        with open(file_path, "rb") as f:

            for chunk in iter(lambda: f.read(4096), b""):

                sha256.update(chunk)

        return sha256.hexdigest()

    except:

        return None


def quarantine(file_path):

    if not os.path.exists(QUARANTINE_FOLDER):

        os.mkdir(QUARANTINE_FOLDER)

    try:

        shutil.move(file_path, QUARANTINE_FOLDER)

        print(Fore.MAGENTA + f"[QUARANTINE] File moved to {QUARANTINE_FOLDER}")

    except:

        pass


def scan_file(file_path):

    filename = os.path.basename(file_path)

    if filename in IGNORE_FILES:

        return False

    try:

        with open(file_path, "r", errors="ignore") as f:

            content = f.read()

            for sig in signatures:

                if sig in content:

                    file_hash = get_hash(file_path)

                    print(Fore.RED +
                          f"[ALERT] Malware detected: {sig} in {file_path}")

                    print(Fore.YELLOW + f"SHA256: {file_hash}")

                    quarantine(file_path)

                    return True

    except:

        pass

    return False


def scan_folder(folder):

    files = []

    for root, dirs, filenames in os.walk(folder):

        dirs[:] = [d for d in dirs if d not in IGNORE_FOLDERS]

        for name in filenames:

            files.append(os.path.join(root, name))

    threats = 0

    print(Fore.CYAN + "\n[SCAN] Starting analysis...\n")

    for file in tqdm(files, desc="Scanning files"):

        if scan_file(file):

            threats += 1

    print(Fore.GREEN + "\n[RESULT]")

    print("Files scanned:", len(files))

    print("Threats found:", threats)

    print("")


def menu():

    print("1 - Scan file")

    print("2 - Scan folder")

    print("3 - Exit")

